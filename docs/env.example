# =============================================================================
# Supabase Configuration
# Get these from: https://supabase.com/dashboard → Project Settings → API
# =============================================================================

NODE_ENV=local
ENVIRONMENT=local
LOG_LEVEL=DEBUG

# =============================================================================
# Together API Key
# =============================================================================
TOGETHER_API_KEY=[your-together-api-key]

# Project URL (used by both frontend and backend). Use trailing slash (required for Storage API).
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co/
SUPABASE_URL=https://[project-ref].supabase.co/

# Anon/Public Key (safe for client-side use - MUST be the anon key, not service key)
NEXT_PUBLIC_SUPABASE_ANON_KEY=[your-anon-key]

# Service Role Key (server-side only, keep secret!). Some code also checks SUPABASE_KEY.
SUPABASE_SERVICE_KEY=[your-service-role-key]

# JWT Secret (for validating tokens)
SUPABASE_JWT_SECRET=[your-jwt-secret]

# Storage bucket name
SUPABASE_STORAGE_BUCKET=documents

# =============================================================================
# Database Configuration (Supabase PostgreSQL)
# =============================================================================
# Use the POOLER connection when the direct host (db.[project-ref].supabase.co) does not
# resolve on your network (e.g. "nodename nor servname provided, or not known").
# Pooler: port 6543 (transaction mode). Direct: port 5432.
# =============================================================================

# Recommended: pooler URL (works when direct DB host does not resolve). User must be postgres.[project-ref].
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Optional: only if you need a different host for Alembic migrations (e.g. direct). Leave unset to use DATABASE_URL as-is.
# DB_MIGRATION_HOST=db.[project-ref].supabase.co

# Fallback when DATABASE_URL is not set (app builds URL from these). Use pooler host + port 6543 for same behavior.
DB_HOST=aws-0-us-west-2.pooler.supabase.com
DB_PORT=6543
DB_USER=postgres.[project-ref]
DB_PASSWORD=[your-database-password]
DB_NAME=postgres
# =============================================================================
# Application Settings
# =============================================================================

# API URL (frontend uses this to call backend)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Base URL used by API when generating shareable links
WEB_BASE_URL=http://localhost:3000

# Secret key for session encryption
SECRET_KEY=change-me-in-production

# =============================================================================
# Development Settings (disable in production!)
# =============================================================================

DEBUG=false
DEV_USER_ID=00000000-0000-0000-0000-000000000001

# =============================================================================
# Upload Settings
# =============================================================================

MAX_UPLOAD_SIZE_MB=10
