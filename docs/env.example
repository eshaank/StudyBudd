# StudyBudd Environment Variables
# Copy this file to the project root as .env and fill in your values

# =============================================================================
# Supabase Configuration
# Get these from: https://supabase.com/dashboard → Project Settings → API
# =============================================================================

# Project URL (used by both frontend and backend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_URL=https://your-project-id.supabase.co

# Anon/Public Key (safe for client-side use)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key (server-side only, keep secret!)
SUPABASE_SERVICE_KEY=your-service-role-key-here

# JWT Secret (for validating tokens)
# Found in: Project Settings → API → JWT Settings
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Storage bucket name
SUPABASE_STORAGE_BUCKET=documents

# =============================================================================
# Database (Supabase Postgres)
# Get from: Supabase Dashboard → Project Settings → Database → Connection string
# =============================================================================

# Direct Postgres connection (use "URI" mode, copy connection string)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# =============================================================================
# Application Settings
# =============================================================================

# API URL (used by frontend to call backend)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Together AI (for chat/LLM)
# Get from: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your-together-api-key

# Secret key for session encryption (generate a random string for production)
SECRET_KEY=change-me-in-production

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# =============================================================================
# Development Settings
# WARNING: Never enable these in production!
# =============================================================================

# Enable debug mode (bypasses authentication)
DEBUG=true

# UUID to use as the authenticated user in dev mode
# This allows testing without logging in
DEV_USER_ID=00000000-0000-0000-0000-000000000001

# Optional: Dev access token for frontend (not required if DEBUG=true on backend)
# NEXT_PUBLIC_DEV_ACCESS_TOKEN=dev-token

# =============================================================================
# Upload Settings
# =============================================================================

# Maximum upload size in MB
MAX_UPLOAD_SIZE_MB=10
